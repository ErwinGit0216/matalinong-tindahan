# Anthropic API key — used server-side only in lib/ai.ts, never exposed to the client
ANTHROPIC_API_KEY=

# Supabase project URL — safe to expose to the client (public by design)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to expose to the client, restricted by RLS policies
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-side ONLY, bypasses RLS. Never commit, never
# expose to the client, never log.
SUPABASE_SERVICE_ROLE_KEY=
